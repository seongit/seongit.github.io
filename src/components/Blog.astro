---
import { siteConfig } from "../config";
import { fetchBlogPosts } from "../utils/rss.js";

const posts = await fetchBlogPosts(siteConfig.blog?.rss, 3);
const hasBlogPosts = posts.length > 0;
---

{
  hasBlogPosts && (
    <section id="articles" class="p-8 sm:p-12 md:p-16 lg:p-24 bg-page">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="type-section text-ink">{siteConfig.blog.title}</h2>
            <div class="w-[75px] h-[5px] mt-3 rounded-full bg-accent" />
          </div>

          <div class="lg:col-span-8">
            <p class="text-base sm:text-lg text-ink/70">
              {siteConfig.blog.description}
            </p>

            <div class="mt-8 grid gap-6 md:grid-cols-3">
              {posts.map((post) => (
                <a
                  href={post.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group overflow-hidden rounded-lg border border-ink/15 bg-surface transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-accent"
                >
                  <div class="aspect-[16/9] border-b border-ink/10">
                    {post.image ? (
                      <img
                        src={post.image}
                        alt=""
                        loading="lazy"
                        class="h-full w-full object-cover opacity-85 transition duration-300 group-hover:opacity-100"
                      />
                    ) : (
                      <div class="flex h-full items-center justify-center px-6 text-center text-sm font-bold text-ink/55">
                        {post.title}
                      </div>
                    )}
                  </div>

                  <div class="space-y-3 p-5">
                    {post.date && (
                      <p class="type-role text-xs text-ink/55">{post.date}</p>
                    )}
                    <h3 class="line-clamp-2 min-h-[3.5rem] text-lg font-bold leading-7 text-ink">
                      {post.title}
                    </h3>
                    <p class="line-clamp-2 text-sm leading-6 text-ink/70">
                      {post.description}
                    </p>
                    <span
                      class="inline-flex items-center gap-1 pt-2 text-sm font-bold text-accent transition-colors group-hover:text-ink"
                    >
                      자세히 보기
                      <svg
                        class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M7 17L17 7M17 7H7M17 7V17"
                        />
                      </svg>
                    </span>
                  </div>
                </a>
              ))}
            </div>

            {siteConfig.social.blog && (
              <div class="mt-8 flex justify-center">
                <a
                  href={siteConfig.social.blog}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-accent px-5 py-2.5 text-sm font-bold text-accent transition hover:bg-accent hover:text-page"
                >
                  블로그로 이동
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 17L17 7M17 7H7M17 7V17"
                    />
                  </svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}
