---
import { siteConfig } from "../config";

const { resumeHero, aboutMe } = siteConfig;

const iconPaths = {
  mail: [
    "M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z",
    "M3 7l9 6l9 -6",
  ],
  book: [
    "M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0",
    "M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0",
    "M3 6v13",
    "M12 6v13",
    "M21 6v13",
  ],
  portfolio: [
    "M10 6h4",
    "M10 12h4",
    "M10 18h4",
    "M5 6h.01",
    "M5 12h.01",
    "M5 18h.01",
    "M19 6h.01",
    "M19 12h.01",
    "M19 18h.01",
  ],
};
---

<section id="hero" class="resume-hero bg-page">
  <div class="bg-accent text-page">
    <div
      class="mx-auto flex max-w-6xl flex-col items-center px-6 pb-10 pt-12 text-center sm:px-10 sm:pb-12 sm:pt-14 lg:px-12"
    >
      <p class="text-sm font-bold text-page/70 sm:text-base">
        {resumeHero.koreanName}
      </p>

      <h1
        class="mt-3 font-role text-4xl font-bold leading-tight text-page sm:text-6xl lg:text-7xl"
      >
        {resumeHero.englishName}
      </h1>

      <div
        class="mt-5 flex w-full max-w-3xl items-center justify-center gap-5 text-page/75"
      >
        <span class="h-px flex-1 bg-page/55"></span>
        <p class="font-role text-xs font-medium sm:text-sm">
          {resumeHero.role}
        </p>
        <span class="h-px flex-1 bg-page/55"></span>
      </div>

      <div
        class="mt-8 grid w-full max-w-4xl grid-cols-1 gap-4 text-page/85 sm:grid-cols-3 sm:divide-x sm:divide-page/35"
      >
        {
          resumeHero.contacts.map((contact) => (
            <a
              href={contact.href}
              aria-label={contact.label}
              class="flex flex-col items-center gap-2 px-4 py-1 transition-colors hover:text-page"
              {...(contact.href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                {iconPaths[contact.icon].map((d) => (
                  <path d={d} />
                ))}
              </svg>
              <span class="text-xs font-medium sm:text-sm">{contact.text}</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-6xl flex-col gap-8 border-b border-accent/25 px-6 py-10 sm:px-10 md:flex-row md:items-center lg:px-12 lg:py-12"
  >
    <div class="relative mx-auto h-40 w-40 shrink-0 md:mx-0 md:h-48 md:w-48">
      <div class="absolute inset-0 rounded-full border border-accent/35"></div>
      <img
        src={resumeHero.profileImage}
        alt={resumeHero.profileAlt}
        class="absolute inset-2 h-[calc(100%-1rem)] w-[calc(100%-1rem)] rounded-full object-cover"
        width="584"
        height="584"
      />
    </div>

    <div class="flex-1 text-ink">
      <p class="text-sm font-bold text-accent sm:text-base">
        {resumeHero.role}
      </p>

      <h2
        class="mt-3 text-balance text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl"
      >
        <span class="block">{resumeHero.greeting}</span>
        <span class="block"><span data-rotator-word data-rotator-words={JSON.stringify(resumeHero.rotatorWords)} class="rotator-word inline-block text-accent" aria-live="polite">{resumeHero.rotatorWords[0]}</span><span data-rotator-particle>{resumeHero.particle}</span> {resumeHero.assetSuffix}</span>
        <span class="block">{resumeHero.closing}</span>
      </h2>

      <div class="mt-6 space-y-3 text-sm leading-7 text-ink/80 sm:text-base">
        {
          aboutMe.slice(1).map((paragraph) => (
            <p>
              {paragraph.map((segment) =>
                segment.bold ? (
                  <strong class="font-bold text-ink">{segment.text}</strong>
                ) : (
                  segment.text
                ),
              )}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const rotator = document.querySelector("[data-rotator-word]");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (rotator && !prefersReducedMotion) {
    const particle = document.querySelector("[data-rotator-particle]");
    const words = JSON.parse(rotator.dataset.rotatorWords || "[]");
    let activeIndex = 0;
    const hasBatchim = (word) => {
      const code = word.charCodeAt(word.length - 1);
      return code >= 0xac00 && code <= 0xd7a3 && (code - 0xac00) % 28 !== 0;
    };

    window.setInterval(() => {
      if (words.length < 2) return;
      activeIndex = (activeIndex + 1) % words.length;
      rotator.classList.add("is-changing");

      window.setTimeout(() => {
        const nextWord = words[activeIndex];
        rotator.textContent = nextWord;
        if (particle) {
          particle.textContent = hasBatchim(nextWord) ? "을" : "를";
        }
        rotator.classList.remove("is-changing");
      }, 180);
    }, 1800);
  }
</script>

<style>
  .rotator-word {
    transform: translateY(0);
    opacity: 1;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .rotator-word.is-changing {
    transform: translateY(0.25rem);
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .rotator-word {
      transition: none;
    }
  }
</style>
