---
import { siteConfig } from "../config";

const { resumeHero, aboutMe } = siteConfig;
const webHeroContacts = resumeHero.contacts.filter(
  (contact) => contact.label !== "Portfolio",
);

const iconPaths = {
  mail: [
    "M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z",
    "M3 7l9 6l9 -6",
  ],
  book: [
    "M3 19a9 9 0 0 1 9 0a9 9 0 0 1 9 0",
    "M3 6a9 9 0 0 1 9 0a9 9 0 0 1 9 0",
    "M3 6v13",
    "M12 6v13",
    "M21 6v13",
  ],
  linkedin: [
    "M8 11v5",
    "M8 8v.01",
    "M12 16v-5",
    "M16 16v-3a2 2 0 0 0-4 0",
    "M3 5a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v14a2 2 0 0 1 -2 2H5a2 2 0 0 1 -2 -2V5z",
  ],
  portfolio: [
    "M4 6h16a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2H4a2 2 0 0 1 -2 -2V8a2 2 0 0 1 2 -2z",
    "M12 12h.01",
    "M16 6V4a2 2 0 0 0-2 -2h-4a2 2 0 0 0-2 2v2",
    "M22 13a18.15 18.15 0 0 1 -20 0",
  ],
};
---

<section id="hero" class="resume-hero bg-page">
  <div class="bg-accent text-page">
    <div
      class="resume-container flex flex-col items-center pb-10 pt-12 text-center sm:pb-12 sm:pt-14"
    >
      {
        resumeHero.koreanName && (
          <p class="text-sm font-bold text-page/70 sm:text-base">
            {resumeHero.koreanName}
          </p>
        )
      }

      <h1
        class={`${resumeHero.koreanName ? "mt-3" : ""} font-role text-4xl font-bold leading-tight text-page sm:text-6xl lg:text-7xl`}
      >
        {resumeHero.englishName}
      </h1>

      <div
        class="mt-5 flex w-full items-center justify-center gap-5 text-page/75"
      >
        <span class="h-px flex-1 bg-page/55"></span>
        <p class="font-role text-xs font-medium sm:text-sm">
          {resumeHero.role}
        </p>
        <span class="h-px flex-1 bg-page/55"></span>
      </div>

      <div
        class="mt-8 grid w-full grid-cols-1 gap-4 text-page/85 sm:grid-cols-3 sm:divide-x sm:divide-page/35"
      >
        {
          webHeroContacts.map((contact) => (
            <a
              href={contact.href}
              aria-label={contact.label}
              class="hero-contact-link flex flex-col items-center gap-2 px-4 py-1 transition-colors hover:text-page focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-page/70"
              {...(contact.href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="hero-contact-icon h-5 w-5"
                aria-hidden="true"
              >
                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                {iconPaths[contact.icon].map((d) => (
                  <path d={d} />
                ))}
              </svg>
              <span class="text-xs font-medium sm:text-sm">{contact.text}</span>
            </a>
          ))
        }
      </div>

      <a
        href="/resume.pdf"
        data-resume-download
        class="mt-6 hidden border border-page/45 px-4 py-2 text-xs font-bold uppercase tracking-normal text-page/85 transition-colors hover:border-page hover:text-page focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-page/70"
      >
        Download PDF
      </a>

      <form
        data-resume-admin-form
        class="mt-5 hidden w-full max-w-xs items-center gap-2"
        aria-label="Resume admin password"
      >
        <input
          data-resume-admin-input
          type="password"
          class="min-w-0 flex-1 border border-page/45 bg-transparent px-3 py-2 text-sm text-page placeholder:text-page/55 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-page/70"
          placeholder="Admin password"
          autocomplete="current-password"
        />
        <button
          type="submit"
          class="border border-page/45 px-3 py-2 text-xs font-bold uppercase text-page/85 transition-colors hover:border-page hover:text-page focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-page/70"
        >
          OK
        </button>
      </form>
    </div>
  </div>

  <div class="resume-container border-b border-accent/25 py-10 lg:py-12">
    <div class="text-ink">
      <p class="text-sm font-bold text-accent sm:text-base">
        {resumeHero.role}
      </p>

      <h2
        class="mt-3 text-balance text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl"
      >
        <span class="block">{resumeHero.greeting}</span>
        <span class="block"><span data-rotator-unit data-rotator-words={JSON.stringify(resumeHero.rotatorWords)} class="rotator-unit inline-block text-accent" aria-live="polite"><span data-rotator-word>{resumeHero.rotatorWords[0]}</span><span data-rotator-particle>{resumeHero.particle}</span></span> {resumeHero.assetSuffix}</span>
        <span class="block">{resumeHero.closing}</span>
      </h2>

      <div
        class="mt-6 space-y-3 text-sm leading-7 text-ink/80 sm:text-base"
        data-hero-evidence
      >
        {
          aboutMe.slice(1).map((paragraph) => (
            <p class="hero-evidence">
              {paragraph.map((segment) =>
                segment.bold ? (
                  <strong class="font-bold text-ink">{segment.text}</strong>
                ) : (
                  segment.text
                ),
              )}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const rotator = document.querySelector("[data-rotator-unit]");
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (rotator && !prefersReducedMotion) {
    const word = rotator.querySelector("[data-rotator-word]");
    const particle = rotator.querySelector("[data-rotator-particle]");
    const words = JSON.parse(rotator.dataset.rotatorWords || "[]");
    let activeIndex = 0;
    const hasBatchim = (word) => {
      const code = word.charCodeAt(word.length - 1);
      return code >= 0xac00 && code <= 0xd7a3 && (code - 0xac00) % 28 !== 0;
    };

    window.setInterval(() => {
      if (words.length < 2) return;
      activeIndex = (activeIndex + 1) % words.length;
      rotator.classList.add("is-changing");

      window.setTimeout(() => {
        const nextWord = words[activeIndex];
        word.textContent = nextWord;
        if (particle) {
          particle.textContent = hasBatchim(nextWord) ? "을" : "를";
        }
        rotator.classList.remove("is-changing");
      }, 180);
    }, 1800);
  }

  const resumeAdminPassword = import.meta.env.PUBLIC_RESUME_ADMIN_PASSWORD;
  const resumeDownload = document.querySelector("[data-resume-download]");
  const resumeAdminForm = document.querySelector("[data-resume-admin-form]");
  const resumeAdminInput = document.querySelector("[data-resume-admin-input]");
  const hero = document.getElementById("hero");
  const adminSessionKey = "resumeAdminEnabled";
  let heroClickCount = 0;
  let heroClickTimer;

  const formatResumeDate = (date) => {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    return `${year}${month}${day}`;
  };

  const showResumeDownload = () => {
    resumeDownload?.classList.remove("hidden");
    resumeAdminForm?.classList.add("hidden");
    resumeAdminForm?.classList.remove("flex");
  };

  const showResumeAdminForm = () => {
    resumeAdminForm?.classList.remove("hidden");
    resumeAdminForm?.classList.add("flex");
    resumeAdminInput?.focus();
  };

  if (resumeDownload) {
    resumeDownload.addEventListener("click", () => {
      resumeDownload.setAttribute(
        "download",
        `${formatResumeDate(new Date())}_김성은_포트폴리오.pdf`,
      );
    });
  }

  if (
    resumeAdminPassword &&
    resumeDownload &&
    sessionStorage.getItem(adminSessionKey) === "true"
  ) {
    showResumeDownload();
  }

  if (resumeAdminPassword && resumeAdminForm && resumeAdminInput) {
    resumeAdminForm.addEventListener("submit", (event) => {
      event.preventDefault();

      if (resumeAdminInput.value === resumeAdminPassword) {
        sessionStorage.setItem(adminSessionKey, "true");
        resumeAdminInput.value = "";
        showResumeDownload();
      }
    });
  }

  if (resumeAdminPassword && hero && resumeDownload && resumeAdminForm) {
    hero.addEventListener("click", () => {
      heroClickCount += 1;
      window.clearTimeout(heroClickTimer);
      heroClickTimer = window.setTimeout(() => {
        heroClickCount = 0;
      }, 2000);

      if (heroClickCount < 5) return;

      heroClickCount = 0;
      window.clearTimeout(heroClickTimer);
      showResumeAdminForm();
    });
  }
</script>

<style>
  .hero-contact-link,
  .hero-contact-icon {
    transition:
      color 180ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .hero-contact-link:hover,
  .hero-contact-link:focus-visible {
    transform: translateY(-0.125rem);
  }

  .hero-contact-link:hover .hero-contact-icon,
  .hero-contact-link:focus-visible .hero-contact-icon {
    transform: translateY(-0.125rem);
  }

  .rotator-unit {
    transform: translateY(0);
    opacity: 1;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .rotator-unit.is-changing {
    transform: translateY(0.25rem);
    opacity: 0;
  }

  .hero-evidence {
    animation: hero-evidence-in 480ms ease-out both;
  }

  .hero-evidence:nth-child(2) {
    animation-delay: 110ms;
  }

  .hero-evidence:nth-child(3) {
    animation-delay: 220ms;
  }

  @keyframes hero-evidence-in {
    from {
      opacity: 0;
      transform: translateY(0.5rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-contact-link,
    .hero-contact-icon,
    .rotator-unit {
      transition: none;
    }

    .hero-contact-link:hover,
    .hero-contact-link:focus-visible,
    .hero-contact-link:hover .hero-contact-icon,
    .hero-contact-link:focus-visible .hero-contact-icon {
      transform: none;
    }

    .hero-evidence {
      animation: none;
    }

    .hero-evidence {
      opacity: 1;
      transform: none;
    }
  }
</style>
