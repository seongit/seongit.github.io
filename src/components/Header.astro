---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasBlog = siteConfig.blog?.rss;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

<header
  id="header"
  class="fixed left-0 right-0 top-0 z-50 hidden translate-y-[-100%] opacity-0 transition-all duration-300 md:block"
>
  <nav class="mx-auto max-w-6xl px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href="#about"
          class="text-sm font-bold text-ink/70 transition-colors hover:text-accent"
        >
          소개
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a
              href="#problem-solving"
              class="text-sm font-bold text-ink/70 transition-colors hover:text-accent"
            >
              주요 성과
            </a>
          </li>
        )
      }
      {
        hasBlog && (
          <li>
            <a
              href="#articles"
              class="text-sm font-bold text-ink/70 transition-colors hover:text-accent"
            >
              Blog
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href="#experience"
              class="text-sm font-bold text-ink/70 transition-colors hover:text-accent"
            >
              경력
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href="#education"
              class="text-sm font-bold text-ink/70 transition-colors hover:text-accent"
            >
              Education
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add(
        "translate-y-0",
        "opacity-100",
        "bg-page/85",
        "backdrop-blur-sm",
        "border-b",
        "border-accent/20",
      );
    } else {
      header?.classList.remove(
        "translate-y-0",
        "opacity-100",
        "bg-page/85",
        "backdrop-blur-sm",
        "border-b",
        "border-accent/20",
      );
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
