---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="resume-section scroll-mt-20">
      <div class="resume-section-inner">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-3">
            <h2 class="resume-heading">Education</h2>
          </div>

          <div class="lg:col-span-9">
            <div class="space-y-8">
              {siteConfig.education.map((edu) => (
                <div class="border-t border-accent/25 pt-6">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-2xl font-bold text-ink">
                        {edu.degree}
                      </h3>
                      <p class="mt-2 text-base sm:text-lg text-ink/75">
                        {edu.school}
                      </p>
                    </div>
                    <span class="type-role text-xs sm:text-sm text-ink/55 mt-2 sm:mt-0">
                      {edu.dateRange}
                    </span>
                  </div>

                  <ul class="list-disc space-y-2 pl-5 text-base leading-7 text-ink/80">
                    {edu.achievements.map((achievement) => (
                      <li>{achievement}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
