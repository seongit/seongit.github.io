---
import { siteConfig } from "../config";
---

<section id="about" class="p-8 sm:p-12 md:p-16 lg:p-24">
  <div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
      <div class="lg:col-span-4">
        <h2 class="type-section text-ink">About Me</h2>
        <div class="w-[75px] h-[5px] mt-3 rounded-full bg-accent"></div>
      </div>

      <div class="lg:col-span-8 space-y-8">
        <div class="space-y-5 text-lg sm:text-xl md:text-2xl text-ink/70">
          <h3 class="text-2xl sm:text-3xl font-bold text-ink">
            {siteConfig.aboutTitle}
          </h3>
          {
            siteConfig.aboutMe.map((paragraph) => (
              <p>
                {paragraph.map((segment) =>
                  segment.bold ? (
                    <strong class="font-bold text-ink">{segment.text}</strong>
                  ) : (
                    segment.text
                  ),
                )}
              </p>
            ))
          }
        </div>

        <div class="pt-4">
          <div class="flex flex-wrap gap-3">
            {
              siteConfig.skills.map((skill) => (
                <span class="px-3 sm:px-4 py-1.5 sm:py-2 border border-ink/40 text-ink rounded-lg text-sm sm:text-base md:text-lg font-bold transition-colors duration-200 hover:border-accent hover:text-accent">
                  {skill}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
