---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const projectBatchSize = 3;
---

{
  hasProjects && (
    <section
      id="problem-solving"
      class="resume-section scroll-mt-20"
      data-problem-solving
    >
      <div
        class="resume-section-inner problem-solving-reveal"
        data-problem-solving-reveal
        data-section-label="Solutions"
      >
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-3">
            <h2 class="resume-heading">Solutions</h2>
          </div>

          <div class="lg:col-span-9">
            <div class="space-y-10" data-projects-list>
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const hasDetail = Boolean(project.detail);
                const isInteractive = Boolean(project.link) || hasDetail;
                const panelClass =
                  "border border-accent/25 bg-surface p-6 sm:p-8";
                const interactiveClass = isInteractive
                  ? "hover:-translate-y-1 hover:border-accent"
                  : "";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div
                    class={`group relative ${index >= projectBatchSize ? "hidden" : ""} ${hasDetail ? "cursor-pointer" : ""}`}
                    data-project-card
                    data-project-skills={JSON.stringify(project.skills || [])}
                    {...(hasDetail
                      ? {
                          "data-detail-trigger": String(index),
                          "data-detail-title": project.name,
                          role: "button",
                          tabindex: "0",
                          "aria-haspopup": "dialog",
                        }
                      : {})}
                  >
                    <Component
                      {...linkProps}
                      class={`block relative transition-all duration-300 ${panelClass} ${interactiveClass}`}
                    >
                      {project.link && (
                        <div
                          class="absolute right-6 top-6 flex h-10 w-10 items-center justify-center bg-accent text-page transition-all duration-300 group-hover:opacity-90"
                        >
                          <svg
                            class="w-4 h-4 sm:w-4.5 sm:h-4.5 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-5">
                        <div class="pr-12">
                          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
                            <h3 class="resume-item-heading">
                              {project.name}
                            </h3>
                            <span class="type-role text-sm text-ink/60">
                              {project.company} · {project.year}
                            </span>
                          </div>
                        </div>

                        <dl
                          class={`space-y-4 ${project.link ? "pr-12 sm:pr-14 md:pr-16" : ""}`}
                        >
                          <div>
                            <dt class="text-sm font-bold text-accent">문제</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.problem}
                            </dd>
                          </div>
                          <div>
                            <dt class="text-sm font-bold text-accent">접근</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.approach}
                            </dd>
                          </div>
                          <div>
                            <dt class="text-sm font-bold text-accent">결과</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.result}
                            </dd>
                          </div>
                        </dl>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span
                                class={`border border-accent/35 px-2.5 py-1 text-xs font-bold text-ink transition-all duration-300 sm:px-3 sm:py-1.5 sm:text-sm ${
                                  project.link ? "group-hover:border-accent group-hover:text-accent" : ""
                                }`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}

                        {hasDetail && (
                          <span class="detail-cue mt-1 inline-flex items-center gap-1.5 text-sm font-bold text-accent transition-transform duration-300 group-hover:translate-x-0.5">
                            자세히 보기
                            <svg
                              class="h-4 w-4"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7l-7 7"
                              />
                            </svg>
                          </span>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>

            {siteConfig.projects.length > projectBatchSize && (
              <div class="mt-8 flex justify-center">
                <button
                  type="button"
                  class="inline-flex items-center gap-2 border border-accent px-5 py-2.5 text-sm font-bold text-accent transition-colors hover:bg-accent hover:text-page focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-page"
                  data-projects-show-more
                >
                  더 보기
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7l-7 -7"
                    />
                  </svg>
                </button>
              </div>
            )}

            <p
              class="mt-8 hidden text-center text-sm font-bold text-ink/60"
              data-projects-empty
            >
              선택한 기술 스택과 연결된 주요 성과가 없습니다.
            </p>
          </div>
        </div>
      </div>

      {siteConfig.projects.map((project, index) =>
        project.detail ? (
          <template data-detail-template={String(index)}>
            {project.detail.metrics && project.detail.metrics.length > 0 && (
              <div class="detail-metrics">
                {project.detail.metrics.map((metric) => (
                  <div class="detail-metric">
                    <p class="detail-metric-label">{metric.label}</p>
                    <p class="detail-metric-value">
                      <span class="detail-metric-before">{metric.before}</span>
                      <span class="detail-metric-arrow" aria-hidden="true">
                        →
                      </span>
                      <span class="detail-metric-after">{metric.after}</span>
                    </p>
                    {metric.delta && (
                      <p class="detail-metric-delta">{metric.delta}</p>
                    )}
                  </div>
                ))}
              </div>
            )}

            <ol class="detail-timeline">
              {project.detail.steps.map((step, stepIndex) => (
                <li class="detail-step">
                  <span class="detail-step-marker" aria-hidden="true">
                    {String(stepIndex + 1).padStart(2, "0")}
                  </span>
                  <div class="detail-step-body">
                    <h4 class="detail-step-title">{step.title}</h4>
                    {step.blocks.map((block) =>
                      block.type === "code" ? (
                        <figure class="detail-code">
                          <pre>
                            <code>{block.value}</code>
                          </pre>
                          {block.caption && (
                            <figcaption>{block.caption}</figcaption>
                          )}
                        </figure>
                      ) : block.type === "image" ? (
                        <figure class="detail-image">
                          <img
                            src={block.value}
                            alt={block.caption || ""}
                            loading="lazy"
                          />
                          {block.caption && (
                            <figcaption>{block.caption}</figcaption>
                          )}
                        </figure>
                      ) : (
                        <p class="detail-text">{block.value}</p>
                      ),
                    )}
                  </div>
                </li>
              ))}
            </ol>

            {project.detail.blogLink && (
              <a
                href={project.detail.blogLink.href}
                target="_blank"
                rel="noopener noreferrer"
                class="detail-blog-link"
              >
                {project.detail.blogLink.label}
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 17L17 7M17 7H7M17 7V17"
                  />
                </svg>
              </a>
            )}
          </template>
        ) : null,
      )}

      <div class="detail-modal hidden" data-detail-modal aria-hidden="true">
        <div class="detail-modal-overlay" data-detail-overlay />
        <div
          class="detail-modal-dialog"
          role="dialog"
          aria-modal="true"
          aria-labelledby="detail-modal-title"
        >
          <div class="detail-modal-header">
            <h3 class="detail-modal-title" id="detail-modal-title" />
            <button
              type="button"
              class="detail-modal-close"
              data-detail-close
              aria-label="닫기"
            >
              <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </button>
          </div>
          <div class="detail-modal-body" data-detail-body />
        </div>
      </div>
    </section>
  )
}

<script is:inline>
  const batchSize = 3;
  const cards = Array.from(document.querySelectorAll("[data-project-card]"));
  const showMoreButton = document.querySelector("[data-projects-show-more]");
  const emptyState = document.querySelector("[data-projects-empty]");
  let visibleCount = batchSize;
  let activeProjectSkill = "";

  function renderProjectCards() {
    const matchingCards = cards.filter((card) => {
      const skills = JSON.parse(card.dataset.projectSkills || "[]");
      return !activeProjectSkill || skills.includes(activeProjectSkill);
    });

    cards.forEach((card) => {
      const index = matchingCards.indexOf(card);
      card.classList.toggle("hidden", index === -1 || index >= visibleCount);
    });

    if (showMoreButton) {
      showMoreButton.toggleAttribute(
        "hidden",
        visibleCount >= matchingCards.length,
      );
    }

    if (emptyState) {
      emptyState.classList.toggle("hidden", matchingCards.length > 0);
    }
  }

  showMoreButton?.addEventListener("click", () => {
    visibleCount = Math.min(visibleCount + batchSize, cards.length);
    renderProjectCards();
  });

  document.addEventListener("tech-filter-change", (event) => {
    activeProjectSkill = event.detail?.skill || "";
    visibleCount = batchSize;
    renderProjectCards();
  });

  renderProjectCards();

  const revealTarget = document.querySelector("[data-problem-solving-reveal]");
  if (revealTarget) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReducedMotion || !("IntersectionObserver" in window)) {
      revealTarget.classList.add("is-visible");
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      observer.observe(revealTarget);
    }
  }

  const detailModal = document.querySelector("[data-detail-modal]");
  const detailBody = detailModal?.querySelector("[data-detail-body]");
  const detailTitle = detailModal?.querySelector("#detail-modal-title");
  const detailClose = detailModal?.querySelector("[data-detail-close]");
  let detailLastFocused = null;

  function openDetail(index, title) {
    const template = document.querySelector(
      `[data-detail-template="${index}"]`,
    );
    if (!template || !detailModal || !detailBody) return;

    detailBody.innerHTML = template.innerHTML;
    if (detailTitle) detailTitle.textContent = title || "";
    detailBody.scrollTop = 0;
    detailLastFocused =
      document.activeElement instanceof HTMLElement
        ? document.activeElement
        : null;
    detailModal.classList.remove("hidden");
    detailModal.setAttribute("aria-hidden", "false");
    detailClose?.focus();
  }

  function closeDetail() {
    if (!detailModal || detailModal.classList.contains("hidden")) return;
    detailModal.classList.add("hidden");
    detailModal.setAttribute("aria-hidden", "true");
    if (detailBody) detailBody.innerHTML = "";
    detailLastFocused?.focus();
    detailLastFocused = null;
  }

  document.querySelectorAll("[data-detail-trigger]").forEach((trigger) => {
    const handleOpen = () =>
      openDetail(trigger.dataset.detailTrigger, trigger.dataset.detailTitle);

    trigger.addEventListener("click", handleOpen);
    trigger.addEventListener("keydown", (event) => {
      if (event.key === "Enter" || event.key === " ") {
        event.preventDefault();
        handleOpen();
      }
    });
  });

  detailClose?.addEventListener("click", closeDetail);

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeDetail();
  });
</script>

<style>
  .problem-solving-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.7s ease-out,
      transform 0.7s ease-out;
  }

  .problem-solving-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .problem-solving-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
