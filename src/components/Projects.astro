---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const projectBatchSize = 3;
---

{
  hasProjects && (
    <section
      id="problem-solving"
      class="resume-section scroll-mt-20"
      data-problem-solving
    >
      <div
        class="resume-section-inner problem-solving-reveal"
        data-problem-solving-reveal
        data-section-label="Solutions"
      >
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-3">
            <h2 class="resume-heading">Solutions</h2>
          </div>

          <div class="lg:col-span-9">
            <div class="space-y-10" data-projects-list>
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const isFirstProject = index === 0;
                const dividerClass = isFirstProject
                  ? ""
                  : "border-t border-accent/25 pt-6";
                const linkClass = project.link
                  ? `${isFirstProject ? "" : "hover:border-accent"} hover:pl-2`
                  : "";
                const iconTopClass = isFirstProject ? "top-0" : "top-6";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div
                    class={`group relative ${index >= projectBatchSize ? "hidden" : ""}`}
                    data-project-card
                  >
                    <Component
                      {...linkProps}
                      class={`block relative transition-all duration-300 ${dividerClass} ${linkClass}`}
                    >
                      {project.link && (
                        <div
                          class={`absolute right-0 ${iconTopClass} flex h-10 w-10 items-center justify-center bg-accent text-page transition-all duration-300 group-hover:opacity-90`}
                        >
                          <svg
                            class="w-4 h-4 sm:w-4.5 sm:h-4.5 md:w-5 md:h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-5">
                        <div class="pr-12">
                          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
                            <h3 class="resume-item-heading">
                              {project.name}
                            </h3>
                            <span class="type-role text-sm text-ink/60">
                              {project.company} · {project.year}
                            </span>
                          </div>
                        </div>

                        <dl
                          class={`space-y-4 ${project.link ? "pr-12 sm:pr-14 md:pr-16" : ""}`}
                        >
                          <div>
                            <dt class="text-sm font-bold text-accent">문제</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.problem}
                            </dd>
                          </div>
                          <div>
                            <dt class="text-sm font-bold text-accent">접근</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.approach}
                            </dd>
                          </div>
                          <div>
                            <dt class="text-sm font-bold text-accent">결과</dt>
                            <dd class="mt-1 text-base leading-7 text-ink/80 sm:text-lg">
                              {project.result}
                            </dd>
                          </div>
                        </dl>

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                            {project.skills.map((skill) => (
                              <span
                                class={`border border-accent/35 px-2.5 py-1 text-xs font-bold text-ink transition-all duration-300 sm:px-3 sm:py-1.5 sm:text-sm ${
                                  project.link ? "group-hover:border-accent group-hover:text-accent" : ""
                                }`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>

            {siteConfig.projects.length > projectBatchSize && (
              <div class="mt-8 flex justify-center">
                <button
                  type="button"
                  class="inline-flex items-center gap-2 border border-accent px-5 py-2.5 text-sm font-bold text-accent transition-colors hover:bg-accent hover:text-page focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-page"
                  data-projects-show-more
                >
                  더 보기
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M19 9l-7 7l-7 -7"
                    />
                  </svg>
                </button>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}

<script is:inline>
  const batchSize = 3;
  const cards = Array.from(document.querySelectorAll("[data-project-card]"));
  const showMoreButton = document.querySelector("[data-projects-show-more]");
  let visibleCount = batchSize;

  function renderProjectCards() {
    cards.forEach((card, index) => {
      card.classList.toggle("hidden", index >= visibleCount);
    });

    if (showMoreButton) {
      showMoreButton.toggleAttribute("hidden", visibleCount >= cards.length);
    }
  }

  showMoreButton?.addEventListener("click", () => {
    visibleCount = Math.min(visibleCount + batchSize, cards.length);
    renderProjectCards();
  });

  renderProjectCards();

  const revealTarget = document.querySelector("[data-problem-solving-reveal]");
  if (revealTarget) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReducedMotion || !("IntersectionObserver" in window)) {
      revealTarget.classList.add("is-visible");
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 },
      );
      observer.observe(revealTarget);
    }
  }
</script>

<style>
  .problem-solving-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition:
      opacity 0.7s ease-out,
      transform 0.7s ease-out;
  }

  .problem-solving-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .problem-solving-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
