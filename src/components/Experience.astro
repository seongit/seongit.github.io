---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="resume-section scroll-mt-20">
      <div class="resume-section-inner">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
          <div class="lg:col-span-3">
            <h2 class="resume-heading">Experience</h2>
          </div>

          <div class="lg:col-span-9">
            <div class="space-y-10">
              {siteConfig.experience.map((exp, index) => (
                <article
                  class={index === 0 ? "" : "border-t border-accent/25 pt-6"}
                >
                  <div class="space-y-4">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <h3 class="resume-item-heading">
                          {exp.company}
                        </h3>
                        <p class="mt-2 text-base text-ink/75 sm:text-lg">
                          {exp.title}
                        </p>
                      </div>
                      <span class="type-role shrink-0 text-sm text-ink/60">
                        {exp.dateRange}
                      </span>
                    </div>

                    <ul class="list-disc space-y-2 pl-5 text-base leading-7 text-ink/80 sm:text-lg">
                      {exp.bullets.map((bullet) => (
                        <li>{bullet}</li>
                      ))}
                    </ul>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
